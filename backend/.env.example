# Application
APP_NAME=Legal CMS
APP_VERSION=0.1.0
DEBUG=true

# Database
POSTGRES_USER=legalcms
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legalcms

# Redis
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-in-production-use-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins for production)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# pgAdmin (optional, for development)
PGADMIN_DEFAULT_EMAIL=admin@legalcms.local
PGADMIN_DEFAULT_PASSWORD=admin

# SiliconFlow AI Service
SILICONFLOW_API_KEY=sk-key
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
SILICONFLOW_MODEL=openai/gpt-oss-20b
SILICONFLOW_TIMEOUT=30
SILICONFLOW_MAX_TOKENS=4096
SILICONFLOW_TEMPERATURE=0.7
