# Database
POSTGRES_USER=legalcms
POSTGRES_PASSWORD=legalcms_dev_password
POSTGRES_DB=legalcms
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://legalcms:legalcms_dev_password@localhost:5432/legalcms

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@legalcms.local
PGADMIN_DEFAULT_PASSWORD=admin

# SiliconFlow AI (add your API key here - DO NOT commit)
# Example: SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# For docker-compose, put the key in the project root `.env` (or export it in your shell)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
SILICONFLOW_MODEL=openai/gpt-oss-20b
