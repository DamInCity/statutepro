# ────────────────────────────────────────────────────────────────────────────
# StatutePro Eval Framework — Environment Variables
# Copy to .env and fill in your values before running evals
# ────────────────────────────────────────────────────────────────────────────

# ── AI Model Provider ────────────────────────────────────────────────────────
# SiliconFlow API key (OpenAI-compatible endpoint)
SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# Optional: Direct OpenAI or Anthropic for comparison benchmarking
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── StatutePro API (for live endpoint testing) ───────────────────────────────
# Local development
STATUTEPRO_API_URL=http://localhost:8000/api/v1

# Staging environment (for red team)
# STATUTEPRO_API_URL=https://api-staging.statutepro.com/api/v1

# JWT token for a test user account (lawyer role)
STATUTEPRO_API_TOKEN=your-jwt-token-here

# JWT token for a test admin account
STATUTEPRO_ADMIN_TOKEN=your-admin-jwt-token-here

# JWT token for a client portal test account
STATUTEPRO_CLIENT_TOKEN=your-client-jwt-token-here

# ── promptfoo Settings ───────────────────────────────────────────────────────
# Cache directory to avoid re-running identical prompts during dev
PROMPTFOO_CACHE_PATH=.cache/promptfoo

# Set to 'true' to share results publicly (generates a URL)
# PROMPTFOO_SHARE=false

# ── LLM Grader ───────────────────────────────────────────────────────────────
# Model used to grade llm-rubric assertions (defaults to OpenAI if set)
# LLM_RUBRIC_PROVIDER=openai:gpt-4o-mini
# If you only have SiliconFlow, use a capable model as grader:
# PROMPTFOO_LLM_PROVIDER=openai:Qwen/Qwen3-235B-A22B
